{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceClone",
  "version": "../package.json",
  "identifier": "com.voiceclone.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoiceClone",
        "width": 1040,
        "height": 760,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/voiceclone-backend"],
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  }
}
