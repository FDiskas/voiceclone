{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core permissions plus spawning the bundled backend sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/voiceclone-backend", "sidecar": true }]
    }
  ]
}
