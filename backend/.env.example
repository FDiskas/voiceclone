# Copy to .env and adjust. All vars are prefixed VOICECLONE_.

# Engine: "fake" (sine tone, no model needed) or "omnivoice" (real model).
VOICECLONE_ENGINE=fake

# OmniVoice settings (only used when ENGINE=omnivoice).
VOICECLONE_MODEL_ID=k2-fsa/OmniVoice
VOICECLONE_DEVICE=auto      # auto | cpu | cuda:0 | mps
VOICECLONE_DTYPE=auto       # auto | float16 | float32
VOICECLONE_NUM_STEP=32

# Transcription: "fake" (placeholder) or "whisper" (faster-whisper).
VOICECLONE_TRANSCRIBER=fake
VOICECLONE_WHISPER_MODEL_SIZE=base    # tiny | base | small | medium | large-v3
VOICECLONE_WHISPER_COMPUTE_TYPE=auto  # auto | int8 | float16 | float32

# Where SQLite + reference audio are stored (defaults to backend/data).
# VOICECLONE_DATA_DIR=/absolute/path/to/data
